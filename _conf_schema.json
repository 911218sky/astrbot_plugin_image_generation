      "gemini": {
        "name": "Gemini 接口",
        "hint": "使用 Gemini 的圖像生成接口",
        "items": {
          "name": {
            "description": "適配器名稱",
            "hint": "用於區分不同適配器的名稱,生圖模型格式為 '適配器名稱/模型名稱'",
            "type": "string",
            "default": ""
          },
          "base_url": {
            "description": "API Base URL",
            "hint": "僅在未選擇系統提供商時需要填寫",
            "type": "string",
            "default": ""
          },
          "proxy": {
            "description": "代理地址",
            "hint": "例如: http://127.0.0.1:7890",
            "type": "string",
            "default": ""
          },
          "api_keys": {
            "description": "API Keys",
            "hint": "僅在未選擇系統提供商時需要填寫",
            "type": "list",
            "default": []
          },
          "available_models": {
            "description": "可用模型列表",
            "hint": "用於 /img model 命令切換時的可選模型。",
            "type": "list",
            "default": [
              "gemini-3-pro-image-preview",
              "gemini-2.5-flash-image",
              "gemini-2.5-flash-image-preview"
