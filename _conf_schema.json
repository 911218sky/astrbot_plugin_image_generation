  "generation": {
    "description": "生圖配置",
    "hint": "圖像生成的行為配置",
    "type": "object",
    "items": {
      "model": {
        "description": "生圖模型",
        "hint": "可以透過 /img model 命令切換,格式為 '適配器名稱/模型名稱',留空自動使用第一個可用模型",
        "type": "string",
        "default": ""
      },
      "timeout": {
        "description": "生圖超時時間（秒）",
        "type": "int",
        "slider": {
          "min": 60,
          "max": 600,
          "step": 10
        },
        "default": 180
      },
      "max_retry_attempts": {
        "description": "最大重試次數",
        "type": "int",
        "slider": {
          "min": 1,
          "max": 15,
          "step": 1
        },
        "default": 5
      },
      "max_concurrent_tasks": {
        "description": "最大併發任務數",
        "hint": "同時生成圖片的最大數量,防止資源耗盡",
        "type": "int",
        "slider": {
          "min": 1,
          "max": 100,
          "step": 1
        },
        "default": 3
      },
      "default_aspect_ratio": {
        "description": "預設寬高比",
        "hint": "使用命令生圖時預設使用的圖片寬高比。選擇自動時由模型自行決定",
        "type": "string",
        "default": "自動",
        "options": [
          "自動",
          "1:1",
          "2:3",
          "3:2",
          "3:4",
          "4:3",
          "4:5",
          "5:4",
          "9:16",
          "16:9",
          "21:9"
        ]
      },
      "default_resolution": {
        "description": "預設解析度",
        "hint": "使用命令生圖時預設使用的圖片解析度（僅部分模型支援）",
        "type": "string",
        "default": "1K",
        "options": [
          "1K",
          "2K",
          "4K"
        ]
      },
      "show_generation_info": {
        "description": "顯示成功耗時提示",
        "hint": "生圖成功後，傳送訊息顯示耗時與生成圖片數量，",
        "type": "bool",
        "default": true
      },
      "show_model_info": {
        "description": "顯示模型資訊",
        "hint": "生圖成功後,傳送訊息展示所使用的模型名稱",
        "type": "bool",
        "default": false
      }
    }
  },
  "user_limits": {
    "description": "使用者限制配置",
    "hint": "針對使用者的生圖限制",
    "type": "object",
    "items": {
      "umo_blacklist": {
        "description": "會話 UMO 黑名單",
        "hint": "填寫 unified_msg_origin（UMO）；黑名單中的會話無法使用生圖功能",
        "type": "list",
        "default": []
      },
      "blacklist_block_message": {
        "description": "黑名單拒絕提示文字",
        "hint": "黑名單命中時返回給使用者的文字，留空則不傳送任何文字",
        "type": "string",
        "default": "❌ 當前會話未啟用生圖功能"
      },
      "rate_limit_seconds": {
        "description": "速率限制（秒）",
        "hint": "單個使用者兩次請求之間的最小間隔時間,0 表示不限制",
        "type": "int",
        "slider": {
          "min": 0,
          "max": 60,
          "step": 1
        },
        "default": 0
      },
      "max_image_size_mb": {
        "description": "最大圖片限制 (MB)",
        "hint": "允許上傳的參考圖最大大小,超過此大小的圖片將被忽略",
        "type": "int",
        "slider": {
          "min": 1,
          "max": 30,
          "step": 1
        },
        "default": 10
      },
      "enable_daily_limit": {
        "description": "啟用每日生圖數量限制",
        "hint": "開啟後將限制每個使用者每日生成的圖片數量",
        "type": "bool",
        "default": false
      },
      "daily_limit_count": {
        "description": "每日生圖數量限制次數",
        "hint": "每個使用者每日允許生成的最大圖片數量",
        "type": "int",
        "slider": {
          "min": 1,
          "max": 50,
          "step": 10
        },
        "default": 10
      }
    }
  },
  "safety_audit": {
    "description": "安全稽核配置",
    "hint": "包含生圖前提示詞稽核和生圖後圖片稽核",
    "type": "object",
    "items": {
      "umo_whitelist": {
        "description": "稽核白名單會話 UMO 列表",
        "hint": "填寫會話 unified_msg_origin（UMO），命中的會話將跳過提示詞和圖片稽核流程",
        "type": "list",
        "default": []
      },
      "prompt_audit": {
        "description": "生圖前提示詞稽核",
        "type": "object",
        "items": {
          "blocked_words": {
            "description": "自定義遮蔽詞列表",
            "hint": "包含任一詞時將直接拒絕生圖請求",
            "type": "list",
            "default": []
          },
          "enable_ai_audit": {
            "description": "啟用 AI 提示詞稽核",
            "hint": "開啟後會呼叫對話模型稽核提示詞",
            "type": "bool",
            "default": false
          },
          "ai_provider_id": {
            "description": "AI 稽核 Provider",
            "hint": "可直接選擇用於稽核的對話模型 Provider，留空時使用當前會話模型",
            "type": "string",
            "default": "",
            "_special": "select_provider"
          },
          "ai_prompt": {
            "description": "AI 稽核提示詞",
            "hint": "直接傳送給稽核模型的提示詞，支援 {prompt} 佔位符；未包含時會自動附加使用者提示詞",
            "type": "text",
            "default": "你是生圖安全審核員。請判斷以下使用者提示詞是否安全，且可用於一般圖像生成。\n使用者提示詞：{prompt}\n僅輸出 JSON：{\"allow\": true/false, \"reason\": \"簡短原因\"}。"
          }
        }
      },
      "image_audit": {
        "description": "生圖後圖片稽核",
        "type": "object",
        "items": {
          "enable_ai_audit": {
            "description": "啟用 AI 圖片稽核",
            "hint": "開啟後會在傳送前進行圖片內容稽核",
            "type": "bool",
            "default": false
          },
          "ai_provider_id": {
            "description": "AI 稽核 Provider",
            "hint": "可直接選擇用於稽核的對話模型 Provider，留空時使用當前會話模型",
            "type": "string",
            "default": "",
            "_special": "select_provider"
          },
          "ai_prompt": {
            "description": "AI 稽核提示詞",
            "hint": "直接傳送給稽核模型的提示詞；僅在顯式寫入 {prompt} 佔位符時才會附帶當前提示詞",
            "type": "text",
            "default": "你是圖像內容安全審核員。請判斷輸入圖片是否安全，且可傳送給一般使用者。僅輸出 JSON：{\"allow\": true/false, \"reason\": \"簡短原因\"}。"
          }
        }
      }
    }
  },
  "cache": {
    "description": "快取配置",
    "hint": "圖片快取管理配置",
    "type": "object",
    "items": {
      "max_cache_count": {
        "description": "最大快取圖片數量",
        "hint": "超過此數量將清理舊圖片",
        "type": "int",
        "slider": {
          "min": 10,
          "max": 200,
          "step": 1
        },
        "default": 100
      },
      "cleanup_interval_hours": {
        "description": "定時清理間隔 (小時)",
        "hint": "每隔多少小時清理一次快取",
        "type": "int",
        "slider": {
          "min": 1,
          "max": 24,
          "step": 1
        },
        "default": 24
      }
    }
  },
  "presets": {
    "description": "生圖預設",
    "hint": "可自訂的圖片生成預設。簡單格式：'名稱:提示詞'。進階格式：'名稱:{\"prompt\":\"提示詞\",\"aspect_ratio\":\"16:9\",\"resolution\":\"2K\",\"description\":\"描述\"}'。預設為空列表。",
    "type": "list",
    "default": []
  }
}
